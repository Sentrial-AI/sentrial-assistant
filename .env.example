# Copy to `.env` for local dev, OR paste into Railway Variables one-by-one.
# ---------------------------------------------------------------------------

# REQUIRED ----------------------------------------------------------------
# Anthropic API key. Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Shared bearer token the PWA and iOS Shortcut use to authenticate.
# Generate with: python -m sentrial.core.daemon gen-token
SENTRIAL_TOKEN=

# NOTION ------------------------------------------------------------------
# 1. Create an integration at https://www.notion.so/profile/integrations
#    Install it into the Pursuit workspace (or wherever your tasks live).
# 2. Copy the "Internal Integration Secret" here.
# 3. Open your tasks database in Notion → "•••" → Connect to → pick this integration.
#    (The integration must be explicitly connected per-database — just installing
#    into the workspace isn't enough.)
# 4. Copy the database UUID from its URL below.
#    URL format: notion.so/<workspace>/<name>-<32-char-UUID>?v=...
NOTION_API_KEY=
NOTION_TASKS_DB_ID=

# PUSH NOTIFICATIONS (optional but recommended) ---------------------------
# Generate both VAPID keys with: python -m sentrial.core.daemon gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URL/email for VAPID (any mailto: is fine)
VAPID_CONTACT=mailto:liamtride@gmail.com

# OPTIONAL FALLBACKS ------------------------------------------------------
# Pushover — backup notification channel if web push fails.
PUSHOVER_TOKEN=
PUSHOVER_USER=

# LOCAL MAC ONLY ----------------------------------------------------------
# iMessage sender (ignored on Railway — osascript only runs on macOS).
# LIAM_PHONE=+14155551234

# INFRA -------------------------------------------------------------------
# Port is provided by Railway automatically; override for local dev.
# PORT=8765

# Where persistent SQLite / jobs / deliverables live.
# Railway: volume mounted at /data (set in Dockerfile already).
# Mac local: defaults to ~/Library/Application Support/Sentrial.
# SENTRIAL_DATA_DIR=/data
