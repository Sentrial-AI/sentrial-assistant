# Copy to `.env` for local dev, OR paste into Railway Variables one-by-one.
# ---------------------------------------------------------------------------

# REQUIRED ----------------------------------------------------------------
# Anthropic API key. Get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Shared bearer token the PWA and iOS Shortcut use to authenticate.
# Generate with: python -m sentrial.core.daemon gen-token
SENTRIAL_TOKEN=

# GOOGLE (Gmail + Calendar via OAuth) -------------------------------------
# 1. Google Cloud Console → create OAuth Client ID (Web application).
#    Authorized redirect URI must be exactly: <PUBLIC_BASE_URL>/api/oauth/google/callback
# 2. OAuth consent screen (Branding/Audience/Data Access):
#    - External user type, Testing status
#    - Add yourself as a Test user
#    - Scopes: openid, userinfo.email, userinfo.profile,
#      https://www.googleapis.com/auth/calendar,
#      https://www.googleapis.com/auth/gmail.modify
# 3. Paste the Client ID / Secret here; Sentrial handles token refresh.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public origin Sentrial is reachable at — used to build the OAuth redirect_uri.
# On Railway this is the .up.railway.app URL; for a custom domain, update here.
PUBLIC_BASE_URL=https://sentrial-assistant-production.up.railway.app

# (Optional, future) Notion as a public OAuth integration instead of a fixed
# API key. Leave blank if you're using NOTION_API_KEY below.
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# NOTION ------------------------------------------------------------------
# 1. Create an integration at https://www.notion.so/profile/integrations
#    Install it into the Pursuit workspace (or wherever your tasks live).
# 2. Copy the "Internal Integration Secret" here.
# 3. Open your tasks database in Notion → "•••" → Connect to → pick this integration.
#    (The integration must be explicitly connected per-database — just installing
#    into the workspace isn't enough.)
# 4. Copy the database UUID from its URL below.
#    URL format: notion.so/<workspace>/<name>-<32-char-UUID>?v=...
NOTION_API_KEY=
NOTION_TASKS_DB_ID=

# PUSH NOTIFICATIONS (optional but recommended) ---------------------------
# Generate both VAPID keys with: python -m sentrial.core.daemon gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URL/email for VAPID (any mailto: is fine)
VAPID_CONTACT=mailto:liamtride@gmail.com

# VOICE (Mac-only, Right-Option hotkey) -----------------------------------
# Deepgram key — used for both Nova-3 STT and Aura-2 TTS in Voice Mode.
# https://console.deepgram.com
NOVA3_API_KEY=
# Optional: which Aura-2 voice Sentrial speaks with. Default: aura-2-orion-en.
# Other strong picks: aura-2-helena-en (British warm), aura-2-apollo-en (smooth male),
# aura-2-asteria-en (confident female), aura-2-luna-en (warm female).
SENTRIAL_VOICE=aura-2-orion-en

# OPTIONAL FALLBACKS ------------------------------------------------------
# Pushover — backup notification channel if web push fails.
PUSHOVER_TOKEN=
PUSHOVER_USER=

# LOCAL MAC ONLY ----------------------------------------------------------
# iMessage sender (ignored on Railway — osascript only runs on macOS).
# LIAM_PHONE=+14155551234

# INFRA -------------------------------------------------------------------
# Port is provided by Railway automatically; override for local dev.
# PORT=8765

# Where persistent SQLite / jobs / deliverables live.
# Railway: volume mounted at /data (set in Dockerfile already).
# Mac local: defaults to ~/Library/Application Support/Sentrial.
# SENTRIAL_DATA_DIR=/data
